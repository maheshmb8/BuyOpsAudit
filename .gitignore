audit_engine/config.py

# Generic credentials patterns
*.env
*creds*
*.json

# Exclude any generated Excel audit outputs or text logs
*.xlsx
*.csv
*.log

# --- Python Environment & Junk ---
__pycache__/
*.pyc
.ipynb_checkpoints/
venv/
.venv/

# Exclude scratchpad/garbage scripts
audit_engine/zzz_garbage.py
